# INET Cloud UAT environment template
# Derived from apps/backoffice-web/.env.example.
# Do not place real production/UAT secrets in this example file.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
POS_DATABASE_TARGET=inet_cloud
# POS_ALLOW_SUPABASE_HOST_FOR_INET_UAT=false
DEV_AUTH_USER_ID=
DEV_AUTH_TENANT_ID=
DEV_AUTH_BRANCH_ID=
DEV_AUTH_BRANCH_ROLE=manager
DEV_AUTH_PLATFORM_ROLE=tenant_user

POS_TIMEOUT_ORDER_CREATE_MS=15000
POS_TIMEOUT_PAYMENT_COMPLETE_MS=15000
AUTH_API_TIMEOUT_MS=8000
POS_ORDER_QUEUE_HARD_LIMIT=120
POS_ORDER_QUEUE_STALE_MINUTES=20
POS_PRINT_QUEUE_HARD_LIMIT=250
POS_DEAD_LETTER_WINDOW_MINUTES=60
NEXT_PUBLIC_POS_MONITOR_POLL_MS=30000
NEXT_PUBLIC_PROMPTPAY_PHONE=
NEXT_PUBLIC_PROMPTPAY_PAYEE_NAME=

# Existing INET NOPS QR placeholders from the POS Preview template.
INET_NOPS_ENV=uat
INET_NOPS_MERCHANT_KEY_UAT=
INET_NOPS_MERCHANT_ID_UAT=
INET_NOPS_ALLOW_MISSING_MERCHANT_ID_UAT=false
INET_NOPS_OAUTH_URL_UAT=https://new-ops-poc.inet.co.th/uat/oauth/api/v1/oauth-token
INET_NOPS_ACCESS_TOKEN_URL_UAT=https://new-ops-poc.inet.co.th/uat/api/v1/sandbox/payment-transactions/access-token
INET_NOPS_AP_URL_UAT=https://YOUR_DOMAIN/payment/inet/result
INET_NOPS_CALLBACK_PUBLIC_URL=https://YOUR_DOMAIN/api/payments/inet/callback
INET_NOPS_MERCHANT_KEY_PROD=
INET_NOPS_MERCHANT_ID_PROD=
INET_NOPS_OAUTH_URL_PROD=
INET_NOPS_ACCESS_TOKEN_URL_PROD=
INET_NOPS_AP_URL_PROD=
INET_NOPS_CALLBACK_PUBLIC_URL_PROD=

POS_SLIP_VERIFY_MODE=

# INET Cloud Windows Bridge UAT placeholders.
INET_ENABLED=false
INET_MODE=uat
INET_PAYMENT_BRIDGE_URL=
INET_PAYMENT_BRIDGE_API_KEY=
INET_CALLBACK_SECRET=
INET_TIMEOUT_MS=15000

# INET Cloud database placeholders for the migration target.
# Keep real values in deployment secrets only.
INET_CLOUD_DB_HOST=
INET_CLOUD_DB_PORT=5432
INET_CLOUD_DB_NAME=
INET_CLOUD_DB_USER=
INET_CLOUD_DB_PASSWORD=
INET_CLOUD_DB_SSL=true
DATABASE_URL=
