# INET Cloud PostgreSQL target. Keep real values in deployment secrets only.

POS_DATABASE_TARGET=inet_cloud
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Used by scripts/apply-inet-cloud-postgres-migrations.mjs when psql is not in PATH.
# PSQL_BIN=C:\Program Files\PostgreSQL\16\bin\psql.exe

# These Supabase variables remain required until the Vercel backend is fully
# refactored from supabase-js to direct PostgreSQL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel -> INET VM bridge health check. This lets Vercel verify the INET
# PostgreSQL database without opening port 5432 publicly.
INET_PAYMENT_BRIDGE_URL=http://203.154.39.123:8787
INET_PAYMENT_BRIDGE_API_KEY=replace-with-bridge-api-key
INET_CLOUD_HEALTH_API_KEY=replace-with-health-check-api-key
