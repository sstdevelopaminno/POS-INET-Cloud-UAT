NODE_ENV=production
PORT=8787
SERVICE_NAME=inet-payment-bridge
BRIDGE_API_KEY=replace-with-pos-to-bridge-api-key

# Leave INET_API_BASE_URL empty only when intentionally using mock QR mode.
INET_API_BASE_URL=
INET_OAUTH_PATH=/uat/oauth/api/v1/oauth-token
INET_ACCESS_TOKEN_PATH=/uat/api/v1/sandbox/payment-transactions/access-token
INET_MERCHANT_KEY=replace-with-real-inet-uat-merchant-secret
INET_AP_URL=https://pos-inet-cloud-uat.vercel.app/payment/inet/result
INET_TIMEOUT_MS=12000
INET_QR_EXPIRES_MINUTES=15

# Callback authentication. Prefer HMAC if INET confirms a signing header.
INET_CALLBACK_SECRET=replace-with-callback-shared-secret
INET_CALLBACK_SIGNING_SECRET=
INET_ALLOW_UNSIGNED_CALLBACKS=false

# Optional POS/Supabase settlement update for phase 1.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PAYMENT_TABLE=pos_payment_intents
SUPABASE_PAYMENT_REF_COLUMN=provider_order_id

# Preferred full-system callback path: forward verified INET callbacks to the POS app callback route.
POS_INET_CALLBACK_URL=https://pos-inet-cloud-uat.vercel.app/api/payments/inet/callback
